{
    "name": "qa3d",
    "version": "1.1.2",
    "description": "Quality Assurance 3D - PCA + ICP registration against generated surfaces",
    "author": "Jeff Lynch <jjlynch@bioarch.net>",
    "main": "main.js",
    "scripts": {
        "dev": "electron .",
        "build": "npx electron-builder"
    },
    "devDependencies": {
        "electron": "^41.2.0",
        "electron-builder": "^26"
    },
    "build": {
        "appId": "com.qa3d.app",
        "productName": "QA3D",
        "files": [
            "main.js",
            "preload.js",
            "public/**/*"
        ],
        "extraResources": [
            {
                "from": "sidecar/",
                "to": "sidecar/",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "public/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "icon": "public/icon.png",
            "category": "Science"
        }
    }
}